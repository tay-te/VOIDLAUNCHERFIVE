{
  "name": "void-launcher",
  "version": "2.0.28",
  "description": "Minecraft Modding Client",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "build:renderer": "vite build --config vite.build.renderer.config.ts",
    "build:preload": "vite build --config vite.build.preload.config.ts",
    "build:main": "vite build --config vite.build.main.config.ts",
    "build": "npm run build:renderer && npm run build:preload && npm run build:main",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:publish": "npm run build && electron-builder --publish always"
  },
  "keywords": [
    "minecraft",
    "modding",
    "launcher"
  ],
  "author": "VOID Launcher",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tay-te/VOIDLAUNCHERFIVE.git"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.6.0",
    "@electron-forge/plugin-vite": "^7.6.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.172.0",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.20",
    "electron": "^34.0.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@react-three/drei": "^10.0.0",
    "@react-three/fiber": "^9.0.0",
    "@supabase/supabase-js": "^2.49.0",
    "dompurify": "^3.3.2",
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.3.0",
    "lucide-react": "^0.474.0",
    "marked": "^17.0.4",
    "minecraft-java-core": "^4.2.6",
    "mobx": "^6.13.0",
    "mobx-react-lite": "^4.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "semver": "^7.7.4",
    "skinview3d": "^3.4.1",
    "three": "^0.172.0"
  }
}
